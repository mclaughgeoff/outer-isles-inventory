run = "npm run start"
entrypoint = "server/index.js"

[nix]
channel = "stable-24_05"

[env]
PORT = "3000"

[deployment]
run = ["sh", "-c", "npm run build && npm run start"]
build = ["sh", "-c", "npm install && cd client && npm install && npx vite build"]

[[ports]]
localPort = 3000
externalPort = 80
