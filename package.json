{
  "name": "outer-isles-inventory",
  "version": "1.0.0",
  "description": "Inventory management system for Outer Isles specialty grocery",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npx vite --host 0.0.0.0",
    "build": "cd client && npx vite build",
    "db:migrate": "cd server && node db/migrate.js",
    "db:seed": "cd server && node db/seed.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "start": "node start.js"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "postcss": "^8.4.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  }
}
