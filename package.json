{
  "name": "outer-isles-inventory",
  "version": "1.0.0",
  "description": "Inventory management system for Outer Isles specialty grocery",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npx vite --host 0.0.0.0",
    "build": "cd client && npx vite build",
    "db:migrate": "cd server && node db/migrate.js",
    "db:seed": "cd server && node db/seed.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  }
}
